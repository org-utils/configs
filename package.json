{
  "name": "@dev_config/configs",
  "version": "0.0.1",
  "description": "Shared TypeScript and Prettier configurations for React, Node, and Next.js projects",
  "keywords": [
    "typescript",
    "config",
    "tsconfig",
    "prettier",
    "react",
    "nextjs",
    "node",
    "shared-config"
  ],
  "author": "Anwar <anwarkamal1434@gmail.com>",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/org-utils/configs.git"
  },
  "homepage": "https://github.com/org-utils/configs#readme",
  "bugs": {
    "url": "https://github.com/org-utils/configs/issues"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "sideEffects": false,
  "files": [
    "tsconfig/*.json",
    "prettier/prettier.config.mjs",
    "prettier/.prettierignore",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "exports": {
    "./tsconfig.base.json": "./tsconfig/tsconfig.base.json",
    "./tsconfig.node.json": "./tsconfig/tsconfig.node.json",
    "./tsconfig.next.json": "./tsconfig/tsconfig.next.json",
    "./tsconfig.react.json": "./tsconfig/tsconfig.react.json",
    "./tsconfig.react-library.json": "./tsconfig/tsconfig.react-library.json",
    "./prettier": "./prettier/prettier.config.mjs",
    "./prettierIgnore": "./prettier/.prettierignore",
    "./package.json": "./package.json"
  },
  "peerDependencies": {
    "typescript": ">=5.5.0",
    "prettier": "^3.0.0",
    "@trivago/prettier-plugin-sort-imports": "^4.0.0 || ^5.0.0"
  },
  "peerDependenciesMeta": {
    "prettier": {
      "optional": true
    },
    "@trivago/prettier-plugin-sort-imports": {
      "optional": true
    }
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "prettier": "^3.9.5",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2"
  },
  "scripts": {
    "test": "node --test",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepack": "npm test",
    "prepublishOnly": "npm run format:check"
  }
}
